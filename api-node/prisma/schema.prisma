generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                           Int                   @id @default(autoincrement()) @map("user_id")
  username                                     String                @unique @db.VarChar(50)
  email                                        String                @unique @db.VarChar(100)
  passwordHash                                 String                @map("password_hash") @db.VarChar(255)
  createdAt                                    DateTime?             @default(now()) @map("created_at") @db.Timestamptz(6)
  isActive                                     Boolean?              @default(true) @map("is_active")
  isDeleted                                    Boolean?              @default(false) @map("is_deleted")
  apiKeys                                      ApiKey[]
  auditLogs                                    AuditLog[]
  cycle_counts_cycle_counts_counted_byTousers  cycle_counts[]        @relation("cycle_counts_counted_byTousers")
  cycle_counts_cycle_counts_resolved_byTousers cycle_counts[]        @relation("cycle_counts_resolved_byTousers")
  forecast_scenarios                           forecast_scenarios[]
  inventory_movements                          inventory_movements[]
  pdf_jobs                                     pdf_jobs[]
  userRoles                                    UserRole[]

  @@map("users")
}

model Role {
  id              Int              @id @default(autoincrement()) @map("role_id")
  roleName        String           @unique @map("role_name") @db.VarChar(50)
  isDeleted       Boolean          @default(false) @map("is_deleted")
  dashboards      Dashboard[]
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model UserRole {
  userId    Int     @map("user_id")
  roleId    Int     @map("role_id")
  isDeleted Boolean @default(false) @map("is_deleted")
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id                   Int                   @id @default(autoincrement()) @map("permission_id")
  permissionName       String                @unique @map("permission_name") @db.VarChar(100)
  description          String
  dashboardPermissions DashboardPermission[]
  rolePermissions      RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model ApiKey {
  id        Int      @id @default(autoincrement()) @map("key_id")
  userId    Int      @map("user_id")
  apiKey    String   @unique @map("api_key") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("api_keys")
}

/// Raw Odoo sale.order export — staging for ETL. Join with sale.order.line to populate Sale.
model odoo_sale_orders {
  id                  Int       @id @default(autoincrement())
  odoo_id             String    @unique @map("odoo_id") @db.VarChar(100)
  partner_id           String    @map("partner_id") @db.VarChar(255)
  client_id            Int?      @map("client_id")
  company_id           String?   @map("company_id") @db.VarChar(100)
  pricelist_id         String?   @map("pricelist_id") @db.VarChar(100)
  order_name           String    @map("order_name") @db.VarChar(50)
  location_id          String?   @map("location_id") @db.VarChar(100)
  payment_term_id     String?   @map("payment_term_id") @db.VarChar(20)
  user_id              String?   @map("user_id") @db.VarChar(100)
  x_studio_comentarios String?   @map("x_studio_comentarios") @db.Text
  date_order           DateTime? @map("date_order") @db.Timestamptz(6)
  state                String?   @map("state") @db.VarChar(50)
  created_at           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  client               Client?   @relation(fields: [client_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([client_id], map: "idx_odoo_sale_orders_client")
  @@index([order_name], map: "idx_odoo_sale_orders_order_name")
  @@index([state], map: "idx_odoo_sale_orders_state")
  @@map("odoo_sale_orders")
}

/// Odoo account.move — invoice/journal entry headers
model AccountMove {
  id           Int                @id @default(autoincrement())
  odoo_id      String             @unique @map("odoo_id") @db.VarChar(100)
  move_number  String             @map("move_number") @db.VarChar(100)
  move_type    String             @map("move_type") @db.VarChar(50)
  partner_name String             @map("partner_name") @db.VarChar(255)
  invoice_date DateTime?          @map("invoice_date") @db.Date
  amount_total Decimal            @map("amount_total") @db.Decimal(15, 4)
  state        String             @map("state") @db.VarChar(50)
  currency     String             @default("GTQ") @db.VarChar(10)
  created_at   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  lines        AccountMoveLine[]

  @@index([invoice_date], map: "idx_account_moves_invoice_date")
  @@index([state], map: "idx_account_moves_state")
  @@map("account_moves")
}

/// Odoo account.move.line — invoice/journal entry line items (debit/credit)
model AccountMoveLine {
  id              Int          @id @default(autoincrement())
  move_id         Int          @map("move_id")
  product_sku     String?      @map("product_sku") @db.VarChar(100)
  product_name    String?      @map("product_name") @db.VarChar(255)
  quantity        Decimal?     @db.Decimal(12, 4)
  price_unit      Decimal?     @map("price_unit") @db.Decimal(15, 4)
  debit           Decimal      @default(0) @db.Decimal(15, 4)
  credit          Decimal      @default(0) @db.Decimal(15, 4)
  gl_account_code String       @map("gl_account_code") @db.VarChar(50)
  gl_account_name String       @map("gl_account_name") @db.VarChar(100)
  cost_center     String?      @map("cost_center") @db.VarChar(100)
  created_at      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  move            AccountMove  @relation(fields: [move_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([move_id], map: "idx_aml_move_id")
  @@index([product_sku], map: "idx_aml_product_sku")
  @@index([gl_account_code], map: "idx_aml_gl_account_code")
  @@index([gl_account_code, product_sku], map: "idx_aml_account_product")
  @@map("account_move_lines")
}

model Client {
  id                  Int       @id @default(autoincrement()) @map("client_id")
  odoo_id             String?   @unique @db.VarChar(50)
  clientName          String    @map("client_name") @db.VarChar(100)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  isDeleted           Boolean   @default(false) @map("is_deleted")
  email               String?   @db.VarChar(255)
  phone               String?   @db.VarChar(50)
  first_purchase_date DateTime? @db.Date
  last_purchase_date  DateTime? @db.Date
  total_orders        Int?      @default(0)
  total_spent         Decimal?  @default(0) @db.Decimal(15, 4)
  avg_order_value     Decimal?  @default(0) @db.Decimal(12, 4)
  rfm_recency         Int?
  rfm_frequency       Int?
  rfm_monetary        Int?
  rfm_score           Int?      @default(dbgenerated("((rfm_recency + rfm_frequency) + rfm_monetary)"))
  segment             String?   @db.VarChar(50)
  lifetime_value      Decimal?  @default(0) @db.Decimal(15, 4)
  churn_risk_score    Decimal?  @db.Decimal(5, 2)
  churn_risk_level    String?   @db.VarChar(20)
  cohort_month        DateTime? @db.Date
  last_updated        DateTime? @default(now()) @db.Timestamptz(6)
  returns             Return[]
  sales               Sale[]
  odoo_sale_orders    odoo_sale_orders[]

  @@index([segment], map: "idx_clients_segment")
  @@map("clients")
}

model Product {
  id                  Int                   @id @default(autoincrement()) @map("product_id")
  odoo_id             String?               @unique @db.VarChar(50)
  productName         String                @map("product_name") @db.VarChar(100)
  sku                 String?               @db.VarChar(100)
  cost                Decimal?              @db.Decimal(12, 4)
  category            String?               @db.VarChar(50)
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  isDeleted           Boolean               @default(false) @map("is_deleted")
  shelf_life_days     Int?                  @default(365)
  moq                 Int?                  @default(1)
  supply_type         String?               @default("standard") @db.VarChar(50)
  listPrice           Decimal?              @map("list_price") @db.Decimal(12, 4)
  stockUomName        String?               @map("stock_uom_name") @db.VarChar(50)
  stockUomRatio       Decimal?              @default(1.0) @map("stock_uom_ratio") @db.Decimal(10, 4)
  cycle_counts        cycle_counts[]
  inventory_movements inventory_movements[]
  inventorySnapshots  InventorySnapshot[]
  purchases           Purchase[]
  returns             Return[]
  sales               Sale[]

  @@index([category], map: "idx_products_category")
  @@map("products")
}

model Sale {
  id           Int      @id @default(autoincrement()) @map("sale_id")
  odoo_id      String?  @unique @db.VarChar(50)
  productId    Int      @map("product_id")
  clientId     Int      @map("client_id")
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 4)
  saleDateTime DateTime @map("sale_datetime") @db.Timestamptz(6)
  isDeleted    Boolean  @default(false) @map("is_deleted")
  total_price  Decimal? @default(dbgenerated("(unit_price * (quantity)::numeric)")) @db.Decimal(15, 4)
  uomName      String?  @map("uom_name") @db.VarChar(100)
  uomRatio     Decimal  @default(1) @map("uom_ratio") @db.Decimal(10, 4)
  returns      Return[]
  client       Client   @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product      Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([saleDateTime], map: "idx_sales_datetime")
  @@index([productId], map: "idx_sales_product")
  @@index([clientId], map: "idx_sales_client")
  @@index([productId, saleDateTime], map: "idx_sales_product_datetime")
  @@map("sales_partitioned")
}

model UnitOfMeasure {
  id        Int      @id @default(autoincrement())
  odooId    Int?     @unique @map("odoo_id")
  name      String   @unique @db.VarChar(100)
  category  String?  @db.VarChar(50)
  ratio     Decimal  @default(1) @db.Decimal(10, 4)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("units_of_measure")
}

model Return {
  id             Int      @id @default(autoincrement()) @map("return_id")
  saleId         Int?     @map("sale_id")
  productId      Int      @map("product_id")
  clientId       Int      @map("client_id")
  quantity       Int
  returnReason   String?  @map("return_reason")
  returnDateTime DateTime @default(now()) @map("return_datetime") @db.Timestamptz(6)
  isDeleted      Boolean  @default(false) @map("is_deleted")
  client         Client   @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product        Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sale           Sale?    @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("returns")
}

model Purchase {
  id                     Int        @id @default(autoincrement()) @map("purchase_id")
  odoo_id                String?    @unique @db.VarChar(50)
  productId              Int        @map("product_id")
  quantity               Int
  unitCost               Decimal    @map("unit_cost") @db.Decimal(12, 4)
  purchaseDateTime       DateTime   @default(now()) @map("purchase_datetime") @db.Timestamptz(6)
  isDeleted              Boolean    @default(false) @map("is_deleted")
  supplier_id            Int?
  status                 String?    @default("ordered") @db.VarChar(50)
  order_number           String?    @db.VarChar(100)
  expected_delivery_date DateTime?  @db.Date
  actual_delivery_date   DateTime?  @db.Date
  lead_time_days         Int?
  total_cost             Decimal?   @default(dbgenerated("((quantity)::numeric * unit_cost)")) @db.Decimal(12, 4)
  discount_amount        Decimal?   @default(0) @db.Decimal(12, 4)
  freight_cost           Decimal?   @default(0) @db.Decimal(12, 4)
  quality_score          Int?
  on_time_delivery       Boolean?
  late_days              Int?       @default(0)
  created_by             Int?
  approved_by            Int?
  approved_at            DateTime?  @db.Timestamptz(6)
  notes                  String?
  product                Product    @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  suppliers              suppliers? @relation(fields: [supplier_id], references: [supplier_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([purchaseDateTime], map: "idx_purchases_datetime")
  @@index([productId], map: "idx_purchases_product")
  @@index([supplier_id], map: "idx_purchases_supplier")
  @@index([status], map: "idx_purchases_status")
  @@map("purchases")
}

model InventorySnapshot {
  id                    Int       @id @default(autoincrement()) @map("snapshot_id")
  odoo_id               String?   @unique @db.VarChar(50)
  productId             Int       @map("product_id")
  quantityOnHand        Int       @map("quantity_on_hand")
  snapshotTimestamp     DateTime  @default(now()) @map("snapshot_timestamp") @db.Timestamptz(6)
  isDeleted             Boolean   @default(false) @map("is_deleted")
  location_zone         String?   @default("MAIN") @db.VarChar(50)
  bin_location          String?   @db.VarChar(50)
  batch_number          String?   @db.VarChar(100)
  expiry_date           DateTime? @db.Date
  quality_status        String?   @default("available") @db.VarChar(50)
  reserved_quantity     Int?      @default(0)
  damaged_quantity      Int?      @default(0)
  quarantine_quantity   Int?      @default(0)
  last_cycle_count_date DateTime? @db.Date
  cycle_count_variance  Int?      @default(0)
  min_quantity          Int?
  max_quantity          Int?
  reorder_point         Int?
  unit_cost             Decimal?  @db.Decimal(12, 4)
  notes                 String?
  product               Product   @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([snapshotTimestamp(sort: Desc)], map: "idx_snapshots_timestamp")
  @@index([productId], map: "idx_snapshots_product")
  @@index([productId, snapshotTimestamp(sort: Desc)], map: "idx_snapshots_product_timestamp")
  @@map("inventory_snapshots")
}

model Dashboard {
  id                   Int                   @id @default(autoincrement()) @map("dashboard_id")
  dashboardName        String                @map("dashboard_name") @db.VarChar(255)
  roleId               Int?                  @map("role_id")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  isDeleted            Boolean               @default(false) @map("is_deleted")
  dashboardPermissions DashboardPermission[]
  role                 Role?                 @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("dashboards")
}

model DashboardPermission {
  dashboardId  Int        @map("dashboard_id")
  permissionId Int        @map("permission_id")
  dashboard    Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([dashboardId, permissionId])
  @@map("dashboard_permissions")
}

model AuditLog {
  id        Int      @id @default(autoincrement()) @map("log_id")
  tableName String   @map("table_name") @db.VarChar(50)
  operation String   @db.Char(1)
  recordId  Int      @map("record_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  changedBy Int      @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  user      User     @relation(fields: [changedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("audit_logs")
}

model Kpi {
  id        Int      @id @default(autoincrement()) @map("kpi_id")
  kpiName   String   @map("kpi_name") @db.VarChar(100)
  kpiValue  Decimal  @map("kpi_value") @db.Decimal(15, 4)
  period    String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("kpis")
}

model Forecast {
  id                    Int      @id @default(autoincrement()) @map("forecast_id")
  productId             Int      @map("product_id")
  sku                   String?  @db.VarChar(100)
  forecastDate          DateTime @map("forecast_date") @db.Timestamptz(6)
  predictedDemand       Int      @map("predicted_demand")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  accuracy_score        Decimal? @db.Decimal(5, 4)
  processing_time_ms    Int?
  forecast_horizon      Int?     @default(30)
  model_version         String?  @default("v1.0") @db.VarChar(50)
  feature_importance    Json?
  confidence_factors    Json?
  risk_factors          Json?
  seasonality_component Decimal? @db.Decimal(12, 4)
  trend_component       Decimal? @db.Decimal(12, 4)
  promotional_impact    Decimal? @db.Decimal(12, 4)
  external_factors      Json?
  lower_bound_80        Decimal? @db.Decimal(12, 4)
  upper_bound_80        Decimal? @db.Decimal(12, 4)
  lower_bound_95        Decimal? @db.Decimal(12, 4)
  upper_bound_95        Decimal? @db.Decimal(12, 4)
  actual_demand         Decimal? @db.Decimal(12, 4)
  error_absolute        Decimal? @db.Decimal(12, 4)
  error_percentage      Decimal? @db.Decimal(5, 2)

  @@index([createdAt], map: "idx_forecasts_created_at")
  @@index([forecastDate], map: "idx_forecasts_date")
  @@index([productId], map: "idx_forecasts_product")
  @@map("forecasts")
}

model Recommendation {
  id                  Int      @id @default(autoincrement()) @map("recommendation_id")
  productId           Int      @map("product_id")
  sku                 String?  @db.VarChar(100)
  recommendedQuantity Int      @map("recommended_quantity")
  confidence          Decimal  @db.Decimal(3, 2)
  reason              String
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  status              String?  @default("pending") @db.VarChar(20)

  @@index([createdAt], map: "idx_recommendations_created_at")
  @@index([status], map: "idx_recommendations_status")
  @@map("recommendations")
}

model Insight {
  id          Int      @id @default(autoincrement()) @map("insight_id")
  insightType String   @map("insight_type") @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String
  value       Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "idx_insights_created_at")
  @@index([insightType], map: "idx_insights_type")
  @@map("insights")
}

model customer_segments {
  segment_id         Int       @id @default(autoincrement())
  segment_name       String    @unique @db.VarChar(50)
  description        String?
  min_rfm_score      Int?
  max_rfm_score      Int?
  characteristics    Json?
  marketing_strategy String?
  color_code         String?   @db.VarChar(7)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cycle_counts {
  cycle_count_id                        Int       @id @default(autoincrement())
  product_id                            Int
  location_zone                         String?   @db.VarChar(50)
  bin_location                          String?   @db.VarChar(50)
  batch_number                          String?   @db.VarChar(100)
  system_quantity                       Int
  counted_quantity                      Int
  variance                              Int?      @default(dbgenerated("(counted_quantity - system_quantity)"))
  variance_value                        Decimal?  @db.Decimal(12, 4)
  count_date                            DateTime? @default(now()) @db.Timestamptz(6)
  counted_by                            Int?
  status                                String?   @default("pending") @db.VarChar(50)
  resolution                            String?   @db.VarChar(50)
  resolved_by                           Int?
  resolved_at                           DateTime? @db.Timestamptz(6)
  notes                                 String?
  users_cycle_counts_counted_byTousers  User?     @relation("cycle_counts_counted_byTousers", fields: [counted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products                              Product   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_cycle_counts_resolved_byTousers User?     @relation("cycle_counts_resolved_byTousers", fields: [resolved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([count_date(sort: Desc)], map: "idx_cycle_count_date")
  @@index([product_id], map: "idx_cycle_count_product")
  @@index([status], map: "idx_cycle_count_status")
}

model forecast_scenarios {
  scenario_id       Int       @id @default(autoincrement())
  scenario_name     String    @db.VarChar(100)
  description       String?
  parameters        Json
  base_date         DateTime  @db.Date
  forecast_horizon  Int?      @default(30)
  adjusted_forecast Json
  impact_summary    Json?
  created_by        Int?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  is_active         Boolean?  @default(true)
  users             User?     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([base_date(sort: Desc)], map: "idx_scenarios_date")
  @@index([created_by], map: "idx_scenarios_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_movements {
  movement_id    Int       @id @default(autoincrement())
  odoo_id        String?   @unique @db.VarChar(50)
  product_id     Int
  movement_type  String    @db.VarChar(50)
  quantity       Int
  from_location  String?   @db.VarChar(50)
  to_location    String?   @db.VarChar(50)
  from_batch     String?   @db.VarChar(100)
  to_batch       String?   @db.VarChar(100)
  reference_type String?   @db.VarChar(50)
  reference_id   Int?
  unit_cost      Decimal?  @db.Decimal(12, 4)
  total_value    Decimal?  @db.Decimal(12, 4)
  reason         String?   @db.VarChar(255)
  created_by     Int?
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  notes          String?
  users          User?     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products       Product   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_movements_date")
  @@index([from_location, to_location], map: "idx_movements_location")
  @@index([product_id], map: "idx_movements_product")
  @@index([movement_type], map: "idx_movements_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pdf_jobs {
  id           Int       @id @default(autoincrement())
  job_id       String    @unique @db.Uuid
  user_id      Int
  report_type  String    @db.VarChar(100)
  status       String    @default("queued") @db.VarChar(50)
  result       Json?
  error        String?
