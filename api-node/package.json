{
  "name": "airefill-api",
  "version": "1.0.0",
  "description": "AI Refill API - Node.js monolith",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node migrate.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "load:sale-order": "tsx ../real_data/load-sale-order-to-aurora.ts",
    "validate:sale-order": "node ../real_data/validate-sale-order.mjs",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.645.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.20.0",
    "archiver": "^6.0.1",
    "bcrypt": "^5.1.1",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.8.2",
    "jose": "^5.9.3",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "nanoid": "^5.0.7",
    "pg": "^8.11.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "plotly.js-dist-min": "^3.1.2",
    "react-plotly.js": "^2.6.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^22.18.12",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
