{
  "family": "dagster-airefill",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::200937443798:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::200937443798:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "dagster",
      "image": "200937443798.dkr.ecr.us-east-2.amazonaws.com/dagster-airefill:latest",
      "essential": true,
      "environment": [
        {
          "name": "DAGSTER_HOME",
          "value": "/opt/dagster/dagster_home"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:200937443798:secret:airefill/database/connection-DjhULl:DATABASE_URL::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dagster",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
