# Dagster ML pipeline environment variables
# Copy to .env for local development — never commit .env

# AWS
AWS_REGION=us-east-2
AWS_DEFAULT_REGION=us-east-2

# Database — local development (full connection string)
DATABASE_URL=postgresql://postgres:password@localhost:5432/airefill

# Database — production (fetched from Secrets Manager by the pipeline)
DB_SECRET_NAME=airefill/database/credentials
DB_HOST=<aurora-cluster-endpoint>
DB_PORT=5432
DB_NAME=airefill

# S3 — ML artifacts and pipeline outputs
ML_MODELS_BUCKET=airefill-ml-models
PIPELINE_ARTIFACTS_BUCKET=airefill-pipeline-artifacts

# SageMaker
SAGEMAKER_ROLE_ARN=arn:aws:iam::200937443798:role/<sagemaker-execution-role>
SAGEMAKER_REGION=us-east-2

# Dagster
DAGSTER_HOME=/opt/dagster/dagster_home
